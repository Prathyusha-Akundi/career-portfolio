---
import { Icon } from 'astro-icon/components';
const { publication } = Astro.props;
---

<div class="publication-card group relative bg-accent/5 border border-accent/10 rounded-2xl overflow-hidden hover:border-accent/40 transition-all duration-500 p-6 space-y-4">
  <div class="flex justify-between items-start gap-4">
    <div class="flex-1 min-w-0">
      <span class="text-accent text-[10px] uppercase tracking-widest font-bold">{publication.venue} · {publication.year}</span>
      <h3 class="text-lg font-heading font-bold text-maintext mt-1 leading-snug">{publication.title}</h3>
    </div>
    <a href={publication.link} target="_blank" rel="noopener noreferrer" class="text-accent/75 hover:text-accent transition-colors flex-shrink-0 mt-1">
      <Icon name="mdi:open-in-new" class="w-5 h-5" />
    </a>
  </div>

  <p class="text-subtext text-sm font-body line-clamp-3">
    {publication.summary}
  </p>
</div>

<style is:global>
  .publication-card {
    opacity: 0;
    visibility: hidden;
    transform: translateY(40px);
    transition:
      opacity 0.8s ease-out,
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0.8s;
    will-change: transform, opacity;
  }

  .publication-card.reveal {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateY(0) !important;
  }
</style>
